# ---------------------------------------------------------------------------
# Root / shared (copy values into apps as needed)
# ---------------------------------------------------------------------------

# PostgreSQL / TimescaleDB — matches docker-compose defaults
DATABASE_URL=postgresql+asyncpg://postgres:dev_password@localhost:5432/eco_dashboard

# Redis — local docker-compose
REDIS_URL=redis://localhost:6379/0

# Electricity Maps API (maps integration)
ELECTRICITY_MAPS_API_KEY=
# free | paid — picks default API host unless ELECTRICITY_MAPS_BASE_URL is set
ELECTRICITY_MAPS_TIER=free
# Optional override, e.g. https://api.electricitymaps.com/v3
# ELECTRICITY_MAPS_BASE_URL=

# FastAPI CORS (comma-separated)
# CORS_ORIGINS=http://localhost:3000

# WattTime (grid carbon / marginal emissions)
WATTTIME_USERNAME=
WATTTIME_PASSWORD=

# ---------------------------------------------------------------------------
# apps/web (Next.js) — prefix with NEXT_PUBLIC_ only when exposed to the browser
# ---------------------------------------------------------------------------

# Optional legacy Mapbox token (map page uses OpenStreetMap + Leaflet; not required)
# NEXT_PUBLIC_MAPBOX_TOKEN=

# Upstash Redis (optional serverless Redis for edge/server routes)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Next.js BFF → FastAPI (used by server routes; public URL optional for client tooling)
NEXT_PUBLIC_API_URL=http://localhost:8000
API_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# apps/api — FastAPI loads the same names via pydantic-settings (.env in apps/api)
# ---------------------------------------------------------------------------
# Duplicate DATABASE_URL, REDIS_URL, ELECTRICITY_MAPS_API_KEY, WATTTIME_*
# into apps/api/.env when running the API from that directory.
